# ─── Backend LLM ──────────────────────────────────────────────────────────────
# Options: claude | ollama | none
#   claude  → Anthropic API
#   ollama  → localhost Ollama
#   none    → no LLM; fallback to additional_content
LLM_BACKEND=claude

# ─── Claude (Anthropic) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL_CLAUDE=claude-haiku-4-5-20251001

# ─── Ollama (localhost)) ──────────────────────────────────────────────────
LLM_MODEL_OLLAMA=mistral
OLLAMA_URL=http://localhost:11434/api/chat

# ─── Common ────────────────────────────────────────────────────────────────────
# Generation Temperature (0.0 = deterministic, recommended for generation)
LLM_TEMPERATURE=0.0
